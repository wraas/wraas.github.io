{
  "name": "wraas-tests",
  "version": "1.0.0",
  "description": "Testing suite for W.R.A.A.S. rickroll platform",
  "scripts": {
    "test": "node --test tests/unit/**/*.test.js && npx playwright test",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "test:e2e": "npx playwright test tests/e2e",
    "test:visual": "npx playwright test tests/visual",
    "test:a11y": "npx playwright test tests/a11y",
    "test:all": "npx playwright test"
  },
  "devDependencies": {
    "playwright": "^1.40.0",
    "@axe-core/playwright": "^4.8.0"
  }
}
